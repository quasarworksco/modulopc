rules_version = '2';

// =====================================================================
//  Reglas de seguridad de Firestore
//  Protección Civil Venezuela · Gestión de Insumos
// =====================================================================
//  Requiere que el usuario haya iniciado sesión (Firebase Authentication).
//  PASOS PREVIOS EN FIREBASE CONSOLE:
//   1. Authentication → Sign-in method → habilitar "Correo electrónico/contraseña".
//   2. Crear el primer usuario (desde la app con el código de registro, o aquí).
//   3. (Recomendado) Authentication → Settings → desactivar el alta de cuentas
//      una vez creados los usuarios, para que no se registren personas ajenas.
// =====================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // Solo usuarios autenticados pueden leer y escribir.
    function autenticado() { return request.auth != null; }

    match /productos/{id} {
      allow read, write: if autenticado();
    }
    match /movimientos/{id} {
      allow read, create: if autenticado();
      allow update, delete: if false; // los movimientos son un registro histórico
    }
    match /traslados/{id} {
      allow read, write: if autenticado();
    }
    match /fallecidos/{id} {
      allow read, write: if autenticado();
    }
    match /resumenes/{id} {
      allow read, write: if autenticado();
    }
    match /usuarios/{id} {
      // Cualquier usuario autenticado puede leer la lista y gestionar cuentas
      // desde el panel (el acceso al panel se controla por rol en la app).
      allow read, write: if autenticado();
    }
    match /transferencias/{id} {
      allow read, create: if autenticado();
      allow update, delete: if false; // registro histórico
    }
    match /pacientes/{id} {
      allow read, write: if autenticado();
    }
    match /educacion/{id} {
      allow read, write: if autenticado();
    }
    match /inspecciones/{id} {
      allow read, write: if autenticado();
    }
    match /actividades/{id} {
      allow read, write: if autenticado();
    }
    match /combustible/{id} {
      allow read, write: if autenticado();
    }
  }
}
