rules_version = '2';

// =====================================================================
//  Reglas de seguridad de Firestore
//  Protección Civil Venezuela · Gestión de Insumos
// =====================================================================
//  IMPORTANTE: por defecto se permite lectura/escritura para que la app
//  funcione de inmediato. Antes de usar en producción, activa Firebase
//  Authentication y descomenta el bloque "PRODUCCIÓN" para exigir que el
//  usuario esté autenticado.
// =====================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- MODO DE ARRANQUE (abierto) ----
    match /productos/{id} {
      allow read, write: if true;
    }
    match /movimientos/{id} {
      allow read, write: if true;
    }

    // ---- PRODUCCIÓN (requiere Authentication) ----
    // Comenta el bloque de arriba y descomenta este cuando actives login:
    //
    // match /productos/{id} {
    //   allow read, write: if request.auth != null;
    // }
    // match /movimientos/{id} {
    //   allow read: if request.auth != null;
    //   allow create: if request.auth != null;
    //   allow update, delete: if false; // los movimientos no se editan ni borran
    // }
  }
}
